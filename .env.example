PORT=3000
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional: override $/1M token pricing for cost logs (defaults exist for common models)
# OPENAI_INPUT_COST_PER_1M=0.15
# OPENAI_OUTPUT_COST_PER_1M=0.60

# Cache
CACHE_DIR=./data/cache
FIXTURES_DIR=./data/fixtures

# Use saved ESPN fixtures instead of live API (recommended for local dev)
USE_FIXTURES=true

# Return placeholder summaries without calling OpenAI (good for pipeline testing)
MOCK_LLM=true

# Only allow generating summaries for dates within this many days of today (EST)
MAX_FETCH_DAYS=7

# How far back to look for completed games (days before the summary date)
GAME_LOOKBACK_DAYS=30

# Max recent games per team
GAMES_PER_TEAM=2

# Headlines to include in news prompts
NEWS_HEADLINE_LIMIT=5

# Reddit (league summaries only)
REDDIT_ENABLED=true
REDDIT_POST_LIMIT=10
REDDIT_LISTING_LIMIT=25
REDDIT_USER_AGENT=sports-summaries/1.0.0 (by /u/yourusername)
